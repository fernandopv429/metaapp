# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injected at runtime from user secrets.
# Users configure this via the Secrets panel in the UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Automatically injected at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string
DATABASE_URL="postgres://user:password@host:port/dbname"

META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=

META_WABA_ID=
META_SYSTEM_USER_TOKEN=
META_PHONE_NUMBER_ID=
